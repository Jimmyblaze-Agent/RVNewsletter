---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="RV Nomad News - Get the 100 Best Free Boondocking Spots" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- OpenGraph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Unlock the Best Free RV Spots! Download the 100 Best Free Boondocking Spots PDF." />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="https://images.unsplash.com/photo-1523987355523-c7b5b0dd90a7?auto=format&fit=crop&q=80" />
		
		<!-- Twitter Card Meta Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content="Unlock the Best Free RV Spots! Download the 100 Best Free Boondocking Spots PDF." />
		<meta name="twitter:image" content="https://images.unsplash.com/photo-1523987355523-c7b5b0dd90a7?auto=format&fit=crop&q=80" />

		<title>{title}</title>
	</head>
	<body class="bg-gray-50 text-gray-900 font-sans antialiased flex flex-col min-h-screen">
		<slot />
	</body>
</html>
